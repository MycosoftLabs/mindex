# MINDEX API — copy to `.env` on the host (never commit real secrets).
# See also: MAS repo `infra/mindex-vm/.env.example` for VM-oriented layout.

MINDEX_DB_HOST=localhost
MINDEX_DB_PORT=5432
MINDEX_DB_USER=mindex
MINDEX_DB_PASSWORD=
MINDEX_DB_NAME=mindex

MAS_API_URL=http://192.168.0.188:8001
# MINDEX_API_KEY=
# MINDEX_INTERNAL_SECRET=
# MINDEX_INTERNAL_TOKENS=
# Generate with:
#   python ..\..\platform-infra\scripts\service_tokens.py generate --service mindex
MINDEX_INTERNAL_SERVICE_TOKEN=

REDIS_URL=redis://localhost:6379/0
REDIS_STREAMS_MINDEX_KEY=mindex:events

# Solana: QuickNode mainnet (set full URL in host .env only — never commit token path)
SOLANA_RPC_URL=https://YOUR_SUBDOMAIN.solana-mainnet.quiknode.pro/YOUR_QUICKNODE_TOKEN/
# Ethereum: Infura mainnet — internal MAS/MINDEX jobs only, not public website env
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
# SOLANA_KEYPAIR_PATH=
SOLANA_NETWORK=mainnet-beta
# MYCA SPL mint from MycoDAO (required for Solana ledger binds)
# MYCA_SOLANA_MINT=EzYEwn4R5tNkNGw4K2a5a58MJFQESdf1r4UJrV7cpUF3
# BITCOIN_RPC_URL=http://192.168.0.x:8332/
# BITCOIN_RPC_USER=
# BITCOIN_RPC_PASSWORD=
# BTC_ORDINALS_WALLET=
# HYPERGRAPH_ENDPOINT=http://192.168.0.x:8080
# P1_BASE_URL=
# P1_API_KEY=

NAS_HOST=192.168.0.105
# CIFS share for MINDEX data (library audio must live here — NOT on VM root disk)
NAS_CIFS_URL=//192.168.0.105/mycosoft.com/mindex
NAS_SMB_USER=mycosoft
# NAS_SMB_PASSWORD=   # set in host .env only; used by scripts/setup_mindex_nas_mount.sh
NAS_MOUNT_PATH=/mnt/nas/mindex
MINDEX_NAS_DATA_DIR=/mnt/nas/mindex
LOCAL_STAGING_PATH=/mnt/nas/mindex/staging
# PROMETHEUS_PUSHGATEWAY_URL=
# PROMETHEUS_METRICS_PATH=

# --- Supabase cloud mirror (warm tier: website / Earth Simulator / WorldView) ---
# Writes go to local Postgres first; the supabase_sync agent pushes deltas here.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: override which tables sync (local.table:supabase_table:conflict_col, comma-separated)
# MINDEX_SUPABASE_SYNC_TABLES=core.taxon:mindex_taxa:id,obs.observation:mindex_observations:id

# --- AWS S3 cold backups + snapshots (aws_backup_* agents) ---
AWS_S3_MINDEX_BUCKET=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3-compatible endpoint (MinIO/Wasabi); leave blank for AWS
S3_ENDPOINT_URL=
# Opt-in Glacier Deep Archive offload of cold NAS dirs (NAS-relative, comma list)
# MINDEX_NAS_OFFLOAD_DIRS=archive,scrapes/raw
# MINDEX_NAS_OFFLOAD_MAX_GB=50

# --- Agent orchestrator tuning ---
MINDEX_AGENT_CONCURRENCY=4
MINDEX_AGENT_MAX_PAGES=25
# Domain selector for the all-life vs fungi-only sources (inat/gbif)
MINDEX_DOMAIN_MODE=all

# JSON thresholds for anchor_router / tier policy (MAS may mirror this name)
# MINDEX_ANCHOR_TIER_THRESHOLDS={"defense":50000,"research":10000,"default":0}

NCBI_API_KEY=
CHEMSPIDER_API_KEY=
